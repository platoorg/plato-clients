{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "packages": {
    "typescript": {
      "release-type": "node",
      "package-name": "@platoorg/client"
    },
    "zod": {
      "release-type": "node",
      "package-name": "@platoorg/client-zod"
    },
    "go": {
      "release-type": "go",
      "package-name": "github.com/platoorg/plato-clients/go"
    },
    "ruby": {
      "release-type": "ruby",
      "package-name": "plato_client"
    },
    "elixir": {
      "release-type": "simple",
      "package-name": "plato_client",
      "extra-files": ["mix.exs"]
    },
    "rust": {
      "release-type": "rust",
      "package-name": "plato-client"
    }
  }
}
