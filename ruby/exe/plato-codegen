#!/usr/bin/env ruby
# frozen_string_literal: true

# exe/plato-codegen — CLI entry point for the plato_codegen gem.
#
# Usage:
#   ruby exe/plato-codegen [manifest_path] [output_path]
#
# Defaults:
#   manifest_path => plato-manifest.json
#   output_path   => plato_client.rb

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "plato_codegen"
require "json"
require "fileutils"

# Strip any option flags so positional args stay stable.
args          = ARGV.reject { |a| a.start_with?("--") }
manifest_path = args[0] || "plato-manifest.json"
output_path   = args[1] || "plato_client.rb"

unless File.exist?(manifest_path)
  warn "x  manifest not found: #{File.expand_path(manifest_path)}"
  exit 1
end

begin
  manifest = JSON.parse(File.read(manifest_path))
rescue JSON::ParserError => e
  warn "x  could not parse manifest: #{e.message}"
  exit 1
end

begin
  output = PlatoCodegen.generate(manifest)
rescue ArgumentError => e
  warn "x  invalid manifest: #{e.message}"
  exit 1
end

out_abs = File.expand_path(output_path)
FileUtils.mkdir_p(File.dirname(out_abs))
File.write(out_abs, output)

schema_names = manifest["schemas"]&.map { |s| s["name"] }&.join(", ") || "(none)"

puts "done  ruby client written to #{out_abs}"
puts "      namespace : #{manifest['namespace']}"
puts "      schemas   : #{schema_names}"
